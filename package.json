{
  "name": "woosh-website",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev --turbopack",
    "build": "next build && node scripts/postbuild-copy-public.mjs",
    "start": "next start",
    "lint": "next lint",
    "verify": "pnpm lint && pnpm test:ci && pnpm build",
    "test": "vitest",
    "test:ci": "vitest run tests/unit",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "pnpm build && playwright test",
    "test:all": "pnpm test:ci && pnpm test:integration && pnpm test:e2e",
    "process:posters": "node scripts/process-posters.mjs",
    "generate:videos": "node scripts/generate-videos.mjs",
    "sync:media": "node scripts/sync-media-to-public.mjs",
    "deploy": "vercel build --prod --yes && vercel deploy --prebuilt --prod --yes"
  },
  "dependencies": {
    "embla-carousel": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.15.0",
    "lucide-react": "^0.511.0",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.1.8",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "jsdom": "^26.1.0",
    "serve": "^14.2.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
